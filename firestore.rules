// firestore.rules — Deploy this to Firebase Console
// Go to: Firebase Console → Firestore → Rules → Edit → Paste this → Publish

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Portfolio collection — public READ (for the live site), admin WRITE only
    match /portfolio/{document=**} {

      // Anyone can READ — needed for portfolio to show live data
      allow read: if true;

      // Only authenticated users (admin) can WRITE
      allow write: if request.auth != null;
    }

    // Form Submissions — public CREATE, admin READ/DELETE only
    match /formSubmissions/{document=**} {

      // Anyone can CREATE a new submission
      allow create: if request.resource.data.size() > 0
                    && request.resource.data.keys().hasAll(['name', 'email', 'message']);

      // Only authenticated admins can READ and DELETE
      allow read, delete: if request.auth != null;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
